PORT=5000

# MongoDB
MONGO_URI=mongodb://localhost:27017/contact-form

# Resend (https://resend.com) API key for sending mail
RESEND_API_KEY=your-resend-api-key
# Sender address: onboarding@resend.dev until you verify your own domain on Resend
EMAIL_FROM=onboarding@resend.dev

# Where contact form submissions get delivered
COMPANY_EMAIL=company-inbox@yourcompany.com

# Comma-separated list of allowed frontend origins
CLIENT_ORIGIN=http://localhost:3000
